SONICFRAME_WORKSPACE=workspace
SONICFRAME_SAMPLE_FPS=6
SONICFRAME_DEFAULT_STYLE=balanced

# Required production vision cascade. No motion-heuristic fallback is available.
# YOLO can be local ultralytics weights or a hosted detector endpoint.
SONICFRAME_YOLO_ENDPOINT=http://localhost:9000/detect
# SONICFRAME_YOLO_WEIGHTS=/models/yolo/best.pt
SONICFRAME_GROUNDINGDINO_ENDPOINT=http://localhost:9001/detect
SONICFRAME_SAM_ENDPOINT=http://localhost:9002/segment
SONICFRAME_VLM_ENDPOINT=http://localhost:9003/describe
SONICFRAME_VISION_PROMPTS=person,foot,door,hand,glass,metal object,wooden object,vehicle,animal,falling object,impact,collision
SONICFRAME_MIN_DETECTION_CONFIDENCE=0.25
SONICFRAME_MAX_DETECTIONS_PER_FRAME=12

# Required production audio backend: foley, generative, or hybrid.
SONICFRAME_AUDIO_BACKEND=hybrid
SONICFRAME_FOLEY_DIR=/data/foley
SONICFRAME_AUDIO_ENDPOINT=http://localhost:9010/generate
SONICFRAME_AUDIO_TIMEOUT=60
