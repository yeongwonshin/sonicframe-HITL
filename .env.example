SONICFRAME_WORKSPACE=workspace
SONICFRAME_SAMPLE_FPS=6
SONICFRAME_DEFAULT_STYLE=balanced

# Optional vision cascade. Leave empty for offline motion-heuristic fallback.
# SONICFRAME_VISION_BACKEND=groundingdino
# SONICFRAME_DETECTOR_ENDPOINT=http://localhost:9001/detect
# SONICFRAME_SAM_ENDPOINT=http://localhost:9002/segment
# SONICFRAME_VLM_ENDPOINT=http://localhost:9003/describe
# SONICFRAME_VISION_PROMPTS=person,door,falling object,metal object,glass
# SONICFRAME_YOLO_WEIGHTS=yolov8n.pt

# Optional audio backend. Leave as procedural for offline demo.
SONICFRAME_AUDIO_BACKEND=procedural
